// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────────────────────────────────────────────────────────
// Admin user
// ───────────────────────────────────────────────────────────────────────────
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  tokens       AccessToken[]
}

// ───────────────────────────────────────────────────────────────────────────
// 5-minute access tokens for students. Token is single-use; once redeemed,
// a Submission row is created and the token is marked used.
// ───────────────────────────────────────────────────────────────────────────
model AccessToken {
  id          String      @id @default(cuid())
  code        String      @unique
  testKind    TestKind
  expiresAt   DateTime
  createdAt   DateTime    @default(now())
  createdById String?
  createdBy   AdminUser?  @relation(fields: [createdById], references: [id])
  redeemedAt  DateTime?
  submission  Submission?

  @@index([testKind])
}

enum TestKind {
  MINAT
  BAKAT
}

// ───────────────────────────────────────────────────────────────────────────
// Subtest configuration. For Bakat: 9 subtests (Penalaran Visual, etc.)
// For Minat: 1 "Bidang Minat" subtest + 8 program subtests (A..H).
// ───────────────────────────────────────────────────────────────────────────
model Subtest {
  id           String     @id @default(cuid())
  code         String     @unique
  testKind     TestKind
  name         String
  description  String
  instructions String     @default("")
  durationSec  Int
  orderIndex   Int        @default(0)
  questions    Question[]
}

model Question {
  id            String          @id @default(cuid())
  subtestId     String
  subtest       Subtest         @relation(fields: [subtestId], references: [id], onDelete: Cascade)
  questionNo    Int
  prompt        String
  imageUrl      String?
  imageUrl2     String?
  parts         Int             @default(1)
  options       Json
  correct       Json
  scoringTag    String?
  isExample     Boolean         @default(false)
  inputMode     String          @default("CHOICE")
  createdAt     DateTime        @default(now())

  @@unique([subtestId, questionNo, isExample])
  answers       Answer[]
}

// ───────────────────────────────────────────────────────────────────────────
// Submission = a student attempt. Created when token is redeemed.
// ───────────────────────────────────────────────────────────────────────────
model Submission {
  id            String       @id @default(cuid())
  tokenId       String       @unique
  token         AccessToken  @relation(fields: [tokenId], references: [id])
  testKind      TestKind
  fullName      String?
  gender        String?
  birthPlace    String?
  birthDate     DateTime?
  age           Int?
  grade         String?
  school        String?
  major         String?
  phone         String?
  email         String?
  startedAt     DateTime     @default(now())
  finishedAt    DateTime?
  randomSeed    String
  violationCount   Int       @default(0)
  violationLog     Json      @default("[]")
  flaggedCheating  Boolean   @default(false)
  answers       Answer[]
  result        Result?
}

model Answer {
  id            String      @id @default(cuid())
  submissionId  String
  submission    Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question    @relation(fields: [questionId], references: [id])
  selected      Json
  partialScore  Float       @default(0)
  isCorrect     Boolean     @default(false)
  answeredAt    DateTime    @default(now())

  @@unique([submissionId, questionId])
}

// ───────────────────────────────────────────────────────────────────────────
// Final aggregated result (computed at finalize).
// ───────────────────────────────────────────────────────────────────────────
model Result {
  id              String      @id @default(cuid())
  submissionId    String      @unique
  submission      Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  payload         Json
  iqEstimate      Int?
  topProfiles     Json?
  topPrograms     Json?
  generatedAt     DateTime    @default(now())
}
